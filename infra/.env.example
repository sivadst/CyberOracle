# ══════════════════════════════════════
# CyberOracle Environment Configuration
# ══════════════════════════════════════

# Application
APP_NAME=CyberOracle
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-secure-random-string-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://cyberoracle:cyberoracle_secret@localhost:5432/cyberoracle
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=1

# JWT Auth
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Celery
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# Threat Intelligence APIs
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
OTX_API_KEY=

# ML
ML_MODEL_PATH=./ml/checkpoints
ML_DEVICE=cpu

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000
